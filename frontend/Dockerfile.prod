# Build the static frontend, then serve it from Caddy (which also
# terminates TLS and proxies /api). Build context is the repo root
# (see docker-compose.prod.yml).

FROM node:22-alpine AS build
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
# Same-origin deploy: Caddy proxies /api to the API container.
ENV VITE_API_URL=/api
RUN npm run build

FROM caddy:2-alpine
COPY frontend/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
EXPOSE 80 443
