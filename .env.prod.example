# Copy to .env.prod on the VM and fill in real values.
# Used by: docker compose --env-file .env.prod -f docker-compose.prod.yml ...
# Never commit .env.prod.

# Public domain. Caddy fetches a Let's Encrypt cert for this and TLS-
# terminates here. Must resolve to this VM with ports 80+443 reachable.
DOMAIN=timetabler.rbfe.com.au

POSTGRES_USER=timetabler
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=timetabler

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Public origin(s) users hit, comma-separated. Used for CORS.
CORS_ORIGINS=https://timetabler.rbfe.com.au

# Leave false in production. Admin is bootstrapped below; create other
# users from the admin UI.
ALLOW_REGISTRATION=false

# Admin account created automatically on first boot.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# 50 MB upload cap (matches nginx client_max_body_size).
MAX_UPLOAD_BYTES=52428800
